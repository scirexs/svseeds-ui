{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 140,
  "sortImports": {
    "groups": [
      "side_effect_style",
      "builtin",
      "external",
      ["internal", "subpath"],
      ["parent", "sibling", "index"],
      "style",
      "type",
      "import",
      "unknown"
    ],
    "internalPattern": ["$lib/", "~/", "@/"]
  }
}
