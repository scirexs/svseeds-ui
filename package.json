{
  "name": "svseeds",
  "version": "0.8.0",
  "description": "Simple headless components for Svelte.",
  "type": "module",
  "main": "./index.js",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "svelte": "./index.js"
    }
  },
  "svelte": "./index.js",
  "imports": {
    "#svs/core": "./src/lib/_svseeds/_core.ts",
    "#svs/*": "./src/lib/_svseeds/*"
  },
  "files": [
    "_svseeds",
    "!_svseeds/_core.ts",
    "!_svseeds/dep.json",
    "index.js",
    "index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "svelte",
    "headless",
    "components",
    "ui"
  ],
  "author": "scirexs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scirexs/svseeds-ui.git"
  },
  "peerDependencies": {
    "svelte": "^5.29.0"
  },
  "scripts": {
    "build": "bun run ./src/script/prep.ts && bunx @sveltejs/package && bun run ./src/script/post.ts",
    "check": "bunx svelte-kit sync && bunx svelte-check --tsconfig ./tsconfig.json",
    "fmt": "bunx prettier --write ${BUN_FMT:-./src/lib}",
    "fmt:check": "bunx prettier --check ${BUN_FMT:-./src/lib}",
    "test": "bunx vitest --run ${BUN_TEST:-./tests}",
    "update": "bun update && bunx playwright install chromium",
    "update:full": "bun update --latest && bunx playwright install-deps chromium"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.69.2",
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@vitest/browser-playwright": "^4.1.10",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10",
    "vitest-axe": "^0.1.0",
    "vitest-browser-svelte": "^2.2.1"
  }
}
