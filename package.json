{
  "name": "svseeds",
  "version": "0.6.0",
  "description": "Simple components for Svelte.",
  "type": "module",
  "main": "./index.js",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "svelte": "./index.js"
    }
  },
  "svelte": "./index.js",
  "imports": {
    "#svs/core": "./src/lib/_svseeds/core.ts",
    "#svs/*": "./src/lib/_svseeds/*"
  },
  "files": [
    "_svseeds",
    "!_svseeds/core.ts",
    "!_svseeds/dep.json",
    "index.js",
    "index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "svelte",
    "headless",
    "components",
    "ui"
  ],
  "author": "scirexs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scirexs/svseeds-ui.git"
  },
  "peerDependencies": {
    "svelte": "^5.29.0"
  },
  "scripts": {
    "build": "bun run ./src/script/prep.ts && bunx @sveltejs/package && bun run post",
    "post": "mv ./dist/* ./ && cp ./src/lib/_svseeds/core.ts ./_svseeds && bunx terser --module -m -c -o ./_svseeds/core.js -- ./_svseeds/core.js",
    "check": "bunx svelte-kit sync && bunx svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bunx svelte-kit sync && bunx svelte-check --tsconfig ./tsconfig.json --watch",
    "fmt": "bunx prettier --write ./src/lib",
    "test": "bunx vitest --run ./tests",
    "update": "bun update && bunx playwright install chromium",
    "update:full": "bun update --latest && bunx playwright install-deps chromium"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.65.2",
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.3",
    "@vitest/browser-playwright": "^4.1.9",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.0",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "terser": "^5.48.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vitest-browser-svelte": "^2.1.1"
  }
}
